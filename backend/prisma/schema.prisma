generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  developer
  reviewer
  viewer
}

enum ProjectStatus {
  active
  archived
}

enum TranslationStatus {
  draft
  review
  approved
  published
}

enum JobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum JobItemStatus {
  pending
  processing
  completed
  failed
}

enum ReviewStatus {
  pending
  in_review
  approved
  rejected
}

enum BranchStatus {
  active
  merged
  archived
}

enum QualityMetricSource {
  review
  manual
  job_completion
  editor
}

enum QualityVerdict {
  accurate
  needs_edit
  inaccurate
}

enum ExportJobStatus {
  pending
  processing
  completed
  failed
}

enum ImportSessionStatus {
  pending
  parsing
  preview_ready
  applying
  completed
  failed
  cancelled
}

enum ImportSessionItemAction {
  create
  update
  unchanged
  conflict
  invalid
  skip
}

enum GlossarySuggestionStatus {
  pending
  approved
  rejected
}

enum LocalizationTemplateType {
  form
  page
  modal
  email
  api
  custom
}

enum LocalizationObjectStatus {
  draft
  materialized
}

enum LocalizationObjectGenerationStatus {
  idle
  queued
  generating
  completed
  failed
}

enum LocalizationNodeType {
  section
  field
  button
  label
  placeholder
  hint
  validation
  error
  success
  tooltip
  email_subject
  email_body
  notification
  text
}

model Tenant {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  slug              String    @unique
  plan              String    @default("free")
  planStatus        String    @default("active") @map("plan_status")
  subscriptionSince DateTime? @map("subscription_since")
  monthlyTokenQuota Int?      @map("monthly_token_quota")
  createdAt         DateTime  @default(now()) @map("created_at")

  users              User[]
  projects           Project[]
  translationMemory  TranslationMemory[]
  auditLogs          AuditLog[]
  providerConfigs    ProviderConfig[]
  aiUsageLogs        AiUsageLog[]
  apiRequestLogs     ApiRequestLog[]
  qualityMetrics     TranslationQualityMetric[]
  exportJobs         ExportJob[]
  importSessions     ImportSession[]
  confluenceConnections ConfluenceConnection[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String
  password  String
  role      UserRole @default(developer)
  createdAt DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
  reviews      Review[]
  aiUsageLogs  AiUsageLog[]
  createdJobs      TranslationJob[] @relation("JobCreatedBy")
  importSessions   ImportSession[]
  confluenceConnections ConfluenceConnection[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String
  description String?
  status      ProjectStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKeys          ApiKey[]
  webhooks         Webhook[]
  languages        ProjectLanguage[]
  translationKeys  TranslationKey[]
  translationJobs  TranslationJob[]
  providerConfigs  ProviderConfig[]
  glossary         Glossary?
  branches         ProjectBranch[]
  exportJobs       ExportJob[]
  glossarySuggestions GlossarySuggestion[]
  localizationObjects LocalizationObject[]
  entityCollections   EntityCollection[]
  importSessions      ImportSession[]
  confluenceConnection ConfluenceConnection?

  @@index([tenantId])
  @@map("projects")
}

model EntityCollection {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  slug        String
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  localizationObjects LocalizationObject[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("entity_collections")
}

model ProjectBranch {
  id        String       @id @default(uuid()) @db.Uuid
  projectId String       @map("project_id") @db.Uuid
  name      String
  isDefault Boolean      @default(false) @map("is_default")
  status    BranchStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  mergedAt  DateTime?    @map("merged_at")

  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  translations BranchTranslation[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("project_branches")
}

model BranchTranslation {
  id               String            @id @default(uuid()) @db.Uuid
  branchId         String            @map("branch_id") @db.Uuid
  translationKeyId String            @map("translation_key_id") @db.Uuid
  language         String            @db.VarChar(5)
  value            String
  status           TranslationStatus @default(draft)
  updatedAt        DateTime          @updatedAt @map("updated_at")

  branch         ProjectBranch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  translationKey TranslationKey @relation(fields: [translationKeyId], references: [id], onDelete: Cascade)

  @@unique([branchId, translationKeyId, language])
  @@index([branchId])
  @@map("branch_translations")
}

model Glossary {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @unique @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  terms   GlossaryTerm[]

  @@map("glossaries")
}

model GlossaryTerm {
  id             String  @id @default(uuid()) @db.Uuid
  glossaryId     String  @map("glossary_id") @db.Uuid
  sourceTerm     String  @map("source_term")
  targetTerm     String? @map("target_term")
  doNotTranslate Boolean @default(false) @map("do_not_translate")
  note           String?

  glossary Glossary @relation(fields: [glossaryId], references: [id], onDelete: Cascade)

  @@unique([glossaryId, sourceTerm])
  @@index([glossaryId])
  @@map("glossary_terms")
}

model GlossarySuggestion {
  id             String                   @id @default(uuid()) @db.Uuid
  projectId      String                   @map("project_id") @db.Uuid
  sourceTerm     String                   @map("source_term")
  targetTerm     String?                  @map("target_term")
  doNotTranslate Boolean                  @default(false) @map("do_not_translate")
  confidence     Float
  reason         String?
  status         GlossarySuggestionStatus @default(pending)
  createdAt      DateTime                 @default(now()) @map("created_at")
  reviewedAt     DateTime?                @map("reviewed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([projectId, sourceTerm])
  @@map("glossary_suggestions")
}

model ApiKey {
  id         String  @id @default(uuid()) @db.Uuid
  projectId  String  @map("project_id") @db.Uuid
  name       String
  secretHash String  @map("secret_hash")
  active     Boolean @default(true)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("api_keys")
}

model Webhook {
  id        String  @id @default(uuid()) @db.Uuid
  projectId String  @map("project_id") @db.Uuid
  url       String
  secret    String
  enabled   Boolean @default(true)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("webhooks")
}

model ProjectLanguage {
  id        String  @id @default(uuid()) @db.Uuid
  projectId String  @map("project_id") @db.Uuid
  code      String  @db.VarChar(5)
  isDefault Boolean @default(false) @map("is_default")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([projectId])
  @@map("project_languages")
}

model TranslationKey {
  id          String  @id @default(uuid()) @db.Uuid
  projectId   String  @map("project_id") @db.Uuid
  key         String
  sourceText  String  @map("source_text")
  description String?
  context     String?
  contentType String? @map("content_type") @db.VarChar(20)
  localizationObjectId String? @map("localization_object_id") @db.Uuid

  project           Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  localizationObject LocalizationObject? @relation(fields: [localizationObjectId], references: [id], onDelete: SetNull)
  localizationNode  LocalizationNode?
  translations      Translation[]
  translationJobItems TranslationJobItem[]
  branchTranslations BranchTranslation[]

  @@unique([projectId, key])
  @@index([projectId])
  @@index([localizationObjectId])
  @@map("translation_keys")
}

model LocalizationObject {
  id           String                     @id @default(uuid()) @db.Uuid
  projectId    String                     @map("project_id") @db.Uuid
  collectionId String?                    @map("collection_id") @db.Uuid
  slug         String
  name         String
  description  String?
  templateType LocalizationTemplateType   @default(custom) @map("template_type")
  status       LocalizationObjectStatus   @default(draft)
  generationStatus LocalizationObjectGenerationStatus @default(idle) @map("generation_status")
  generationError  String?              @map("generation_error")
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")

  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collection      EntityCollection?  @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  nodes           LocalizationNode[]
  translationKeys TranslationKey[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([projectId, collectionId])
  @@map("localization_objects")
}

model LocalizationNode {
  id               String               @id @default(uuid()) @db.Uuid
  objectId         String               @map("object_id") @db.Uuid
  parentId         String?              @map("parent_id") @db.Uuid
  sortOrder        Int                  @default(0) @map("sort_order")
  nodeType         LocalizationNodeType @map("node_type")
  slug             String
  label            String?
  sourceText       String?              @map("source_text")
  description      String?
  context          String?
  contentType      String?              @map("content_type") @db.VarChar(20)
  translationKeyId String?              @unique @map("translation_key_id") @db.Uuid

  object         LocalizationObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  parent         LocalizationNode?  @relation("LocalizationNodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       LocalizationNode[] @relation("LocalizationNodeTree")
  translationKey TranslationKey?    @relation(fields: [translationKeyId], references: [id], onDelete: SetNull)

  @@index([objectId, parentId, sortOrder])
  @@map("localization_nodes")
}

model Translation {
  id               String            @id @default(uuid()) @db.Uuid
  translationKeyId String            @map("translation_key_id") @db.Uuid
  language         String            @db.VarChar(5)
  value            String
  status           TranslationStatus @default(draft)
  provider         String?
  version          Int               @default(1)

  translationKey TranslationKey @relation(fields: [translationKeyId], references: [id], onDelete: Cascade)
  reviews        Review[]
  qualityMetrics TranslationQualityMetric[]

  @@index([translationKeyId, language])
  @@map("translations")
}

model TranslationJob {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  createdById String?   @map("created_by_id") @db.Uuid
  status      JobStatus @default(pending)
  provider    String?
  createdAt   DateTime  @default(now()) @map("created_at")

  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?                @relation("JobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     TranslationJobItem[]

  @@index([projectId])
  @@index([createdById])
  @@map("translation_jobs")
}

model TranslationJobItem {
  id               String        @id @default(uuid()) @db.Uuid
  jobId            String        @map("job_id") @db.Uuid
  translationKeyId String        @map("translation_key_id") @db.Uuid
  language         String        @db.VarChar(5)
  status           JobItemStatus @default(pending)
  errorMessage     String?       @map("error_message")

  job            TranslationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  translationKey TranslationKey @relation(fields: [translationKeyId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@map("translation_job_items")
}

model TranslationMemory {
  id             String @id @default(uuid()) @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid
  sourceLanguage String @map("source_language") @db.VarChar(5)
  targetLanguage String @map("target_language") @db.VarChar(5)
  sourceText     String @map("source_text")
  translatedText String @map("translated_text")
  hash           String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, hash])
  @@index([tenantId, hash])
  @@map("translation_memory")
}

model Review {
  id            String       @id @default(uuid()) @db.Uuid
  translationId String       @map("translation_id") @db.Uuid
  reviewerId    String       @map("reviewer_id") @db.Uuid
  status        ReviewStatus @default(pending)
  comment       String?
  createdAt     DateTime     @default(now()) @map("created_at")

  translation Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([translationId])
  @@map("reviews")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  entity    String
  entityId  String   @map("entity_id") @db.Uuid
  action    String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model ProviderConfig {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  projectId String? @map("project_id") @db.Uuid
  provider  String
  config    Json

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("provider_configs")
}

model AiUsageLog {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  userId           String?  @map("user_id") @db.Uuid
  projectId        String?  @map("project_id") @db.Uuid
  jobId            String?  @map("job_id") @db.Uuid
  jobItemId        String?  @map("job_item_id") @db.Uuid
  provider         String
  model            String
  inputTokens      Int      @default(0) @map("input_tokens")
  outputTokens     Int      @default(0) @map("output_tokens")
  estimatedCostUsd Decimal  @default(0) @map("estimated_cost_usd") @db.Decimal(12, 6)
  usedFallback     Boolean  @default(false) @map("used_fallback")
  primaryProvider  String?  @map("primary_provider")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, model, createdAt])
  @@index([projectId, createdAt])
  @@map("ai_usage_logs")
}

model ApiRequestLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @map("tenant_id") @db.Uuid
  method     String
  route      String
  status     Int
  durationMs Int      @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("api_request_logs")
}

model TranslationQualityMetric {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  projectId      String              @map("project_id") @db.Uuid
  translationId  String              @map("translation_id") @db.Uuid
  jobId          String?             @map("job_id") @db.Uuid
  jobItemId      String?             @map("job_item_id") @db.Uuid
  provider       String?
  language       String              @db.VarChar(5)
  translationKey String              @map("translation_key")
  sourceText     String              @map("source_text")
  aiValue        String              @map("ai_value")
  referenceValue String?             @map("reference_value")
  score          Decimal             @db.Decimal(5, 4)
  source         QualityMetricSource
  verdict        QualityVerdict?
  notes          String?
  createdById    String?             @map("created_by_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  translation Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([projectId, createdAt])
  @@index([translationId, createdAt])
  @@map("translation_quality_metrics")
}

model ExportJob {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @map("tenant_id") @db.Uuid
  projectId    String            @map("project_id") @db.Uuid
  format       String            @db.VarChar(20)
  language     String?           @db.VarChar(5)
  statusFilter TranslationStatus @map("status_filter")
  exportStatus ExportJobStatus   @default(pending) @map("export_status")
  rowCount     Int               @default(0) @map("row_count")
  filename     String?
  contentType  String?           @map("content_type")
  storagePath  String?           @map("storage_path")
  errorMessage String?           @map("error_message")
  expiresAt    DateTime?         @map("expires_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  completedAt  DateTime?         @map("completed_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([projectId, createdAt])
  @@map("export_jobs")
}

model ImportSession {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  projectId       String              @map("project_id") @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  sourceType      String              @map("source_type") @db.VarChar(40)
  status          ImportSessionStatus @default(pending)
  statsJson       Json?               @map("stats_json")
  warningsJson    Json?               @map("warnings_json")
  diffSummaryJson Json?               @map("diff_summary_json")
  parseRulesJson  Json?               @map("parse_rules_json")
  storagePath     String?             @map("storage_path")
  originalFilename String?            @map("original_filename")
  errorMessage    String?             @map("error_message")
  startedAt       DateTime?           @map("started_at")
  completedAt     DateTime?           @map("completed_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   ImportSessionItem[]

  @@index([tenantId, createdAt])
  @@index([projectId, createdAt])
  @@map("import_sessions")
}

model ImportSessionItem {
  id               String                  @id @default(uuid()) @db.Uuid
  sessionId        String                  @map("session_id") @db.Uuid
  externalSource   String?                 @map("external_source") @db.VarChar(40)
  externalId       String?                 @map("external_id")
  scope            String?
  key              String
  sourceText       String                  @map("source_text")
  hints            String?
  action           ImportSessionItemAction @default(create)
  error            String?
  warning          String?
  translationKeyId String?                 @map("translation_key_id") @db.Uuid
  beforeJson       Json?                   @map("before_json")
  afterJson        Json?                   @map("after_json")

  session ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, action])
  @@index([sessionId, key])
  @@map("import_session_items")
}

model ConfluenceConnection {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  cloudId          String    @map("cloud_id")
  siteUrl          String    @map("site_url")
  siteName         String?   @map("site_name")
  accessTokenEnc   String    @map("access_token_enc") @db.Text
  refreshTokenEnc  String?   @map("refresh_token_enc") @db.Text
  tokenExpiresAt   DateTime? @map("token_expires_at")
  scopes           String?
  connectedById      String    @map("connected_by_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project    Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connectedBy User                 @relation(fields: [connectedById], references: [id], onDelete: Cascade)
  syncConfig ConfluenceSyncConfig?

  @@index([tenantId])
  @@map("confluence_connections")
}

model ConfluenceSyncConfig {
  id                  String    @id @default(uuid()) @db.Uuid
  connectionId        String    @unique @map("connection_id") @db.Uuid
  pageIds             String[]  @map("page_ids")
  spaceKey            String?   @map("space_key") @db.VarChar(50)
  labelFilter         String?   @map("label_filter")
  parseRulesJson      Json?     @map("parse_rules_json")
  autoApply           Boolean   @default(false) @map("auto_apply")
  lastSyncedAt        DateTime? @map("last_synced_at")
  lastSyncStatus      String?   @map("last_sync_status") @db.VarChar(20)
  lastSyncSummaryJson Json?     @map("last_sync_summary_json")
  lastImportSessionId String?   @map("last_import_session_id") @db.Uuid
  lastErrorMessage    String?   @map("last_error_message")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  connection ConfluenceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("confluence_sync_configs")
}
