NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://translate:translate@localhost:5432/translate_ai?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600

# Default admin (run: make db-seed or bash scripts/seed-admin.sh)
ADMIN_EMAIL=admin@translate.ai
ADMIN_PASSWORD=admin123
ADMIN_TENANT_NAME=Default

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Ollama — use 127.0.0.1 for native Ollama.app (avoids Docker Ollama on localhost when both run)
# Template for local dev: cp backend/.env.dev.example backend/.env
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2:9b
OLLAMA_MODEL_DEFAULT=gemma2:9b
OLLAMA_MODEL_FAST=gemma2:9b
OLLAMA_MODEL_LITERAL=gemma2:9b
OLLAMA_ROUTING_MODE=rules
OLLAMA_CLASSIFIER_MODEL=gemma2:9b
OLLAMA_POLISH_ENABLED=false
OLLAMA_POLISH_MODEL=gemma2:9b
# Per-request timeout in ms (default 600000 = 10 min; CPU inference often needs >2 min)
OLLAMA_TIMEOUT_MS=600000
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.0-flash
# Retries on transient Gemini HTTP errors (502/503/429); 2 = up to 3 total calls per model
GEMINI_TRANSIENT_RETRIES=2
GEMINI_TRANSIENT_RETRY_DELAY_MS=1000
AI_PROVIDER=gemini
AI_PROVIDER_FALLBACK=gemini,ollama
DEFAULT_SOURCE_LANGUAGE=en
# Set true to skip AI calls and return mock translations (fast local dev without Ollama)
MOCK_TRANSLATIONS=false
TRANSLATION_VALIDATION_ENABLED=true
  TRANSLATION_QA_VALIDATORS_ENABLED=true
EXPORT_ASYNC_THRESHOLD=1000
EXPORT_STORAGE_DIR=.exports
EXPORT_JOB_TTL_HOURS=24
SEMANTIC_MEMORY_ENABLED=true
SEMANTIC_MEMORY_THRESHOLD=0.92
EMBEDDING_PROVIDER=openai
EMBEDDING_DIMENSIONS=768
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
