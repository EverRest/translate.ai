NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://translate:translate@postgres:5432/translate_ai?schema=public

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=dev-docker-change-me-in-production
JWT_EXPIRES_IN=3600

# Default admin (created by prisma db seed on API startup)
ADMIN_EMAIL=admin@translate.ai
ADMIN_PASSWORD=admin123
ADMIN_TENANT_NAME=Default

# Set false to use Ollama / cloud AI providers
MOCK_TRANSLATIONS=false

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODEL_DEFAULT=qwen2.5:7b
OLLAMA_MODEL_FAST=llama3.1:8b
OLLAMA_MODEL_LITERAL=llama3.1:8b
OLLAMA_ROUTING_MODE=rules
OLLAMA_CLASSIFIER_MODEL=llama3.1:8b
OLLAMA_POLISH_ENABLED=false
OLLAMA_POLISH_MODEL=llama3.1:8b
# CPU/local Ollama can exceed 2m per item; 600000 = 10 minutes
OLLAMA_TIMEOUT_MS=600000
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
AI_PROVIDER_FALLBACK=gemini,ollama
DEFAULT_SOURCE_LANGUAGE=en

CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://0.0.0.0:5173,http://localhost:4173
